# Required for all non-health Zeus HTTP endpoints.
ZEUS_API_KEY=

# Local development only: allow unauthenticated GET endpoints. Rejected on public binds.
ZEUS_ALLOW_UNAUTH_READS=0

# Optional path to the Hermes executable. Defaults to "hermes" on PATH.
ZEUS_HERMES_BIN=hermes

# Optional API bind settings. Non-loopback binds require a ZEUS_API_KEY of at
# least 16 characters and must be placed behind a TLS reverse proxy/firewall.
ZEUS_HOST=127.0.0.1
ZEUS_PORT=4311

# Bound active API workers, slow clients, and orderly shutdown draining.
ZEUS_API_MAX_CONCURRENT_REQUESTS=32
ZEUS_API_REQUEST_TIMEOUT_SECONDS=10
ZEUS_API_SHUTDOWN_DRAIN_SECONDS=20

# Process-local authentication-failure and authenticated-mutation rate limits.
# Rates accept 1-6000 requests per minute; bursts accept 1-1000 requests.
ZEUS_API_AUTH_FAILURE_RATE_PER_MINUTE=30
ZEUS_API_AUTH_FAILURE_BURST=10
ZEUS_API_MUTATION_RATE_PER_MINUTE=120
ZEUS_API_MUTATION_BURST=30

# Optional durable replay window and bounded record capacity for keyed mutations.
# Retention accepts 60-604800 seconds; capacity accepts 100-1000000 records.
# The values below are the defaults.
ZEUS_API_IDEMPOTENCY_RETENTION_SECONDS=86400
ZEUS_API_IDEMPOTENCY_MAX_RECORDS=10000

# Write secret-safe request and error events to .zeus/logs/api.jsonl.
ZEUS_API_LOG_ENABLED=1

# Optional workspace-local runtime path.
ZEUS_STATE_DIR=.zeus

# Optional: send SIGKILL if SIGTERM does not stop Hermes before the grace timeout.
# Disabled by default to avoid interrupting a still-shutting-down gateway.
ZEUS_STOP_KILL_AFTER_TIMEOUT=0

# Optional lifecycle coordination and readiness settings.
ZEUS_LOCK_TIMEOUT_SECONDS=30
ZEUS_READINESS_TIMEOUT_SECONDS=30
ZEUS_READINESS_INTERVAL_SECONDS=0.5
ZEUS_ALLOW_LEGACY_PID_MARKERS=1

# Optional comma-separated list of host env vars to pass to Hermes child processes.
# Keep empty unless required for proxies or certificate bundles.
ZEUS_ENV_PASSTHROUGH=

# Provider and gateway secrets referenced by bundled templates. Copy this file
# to the trusted workspace ./.env, then import only the names a bot needs with
# `zeus bot create ... --env-from NAME`. A process environment value takes
# precedence over ./.env. Do not pass secrets with legacy `--env NAME=VALUE`;
# command arguments may be exposed in shell history and process listings. After
# copying this file, run `chmod 0600 .env` before adding real secrets.
OPENROUTER_API_KEY=
NOUS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
