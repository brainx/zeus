# Required for mutating Zeus HTTP endpoints.
ZEUS_API_KEY=

# Optional path to the Hermes executable. Defaults to "hermes" on PATH.
ZEUS_HERMES_BIN=hermes

# Optional API bind settings.
ZEUS_HOST=127.0.0.1
ZEUS_PORT=4311

# Optional workspace-local runtime path.
ZEUS_STATE_DIR=.zeus

# Provider and gateway secrets referenced by bundled templates.
OPENROUTER_API_KEY=
NOUS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
